# {{ ansible_managed }}
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ app_name }}
  namespace: {{ namespace | default('default') }}
  annotations:
    kubernetes.io/ingress.class: nginx
    cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  tls:
  - hosts:
    - {{ app_name }}.{{ domain }}
    secretName: {{ app_name }}-tls
  rules:
  - host: {{ app_name }}.{{ domain }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: {{ app_name }}
            port:
              number: {{ service_port | default(container_port) }}
