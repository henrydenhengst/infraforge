# {{ ansible_managed }}
auto {{ name }}
iface {{ name }} inet {{ family | default('static') }}
{% if family == 'static' %}
    address {{ address }}
    netmask {{ netmask | default('255.255.255.0') }}
    gateway {{ gateway | default('') }}
{% endif %}
{% if mtu is defined %}
    mtu {{ mtu }}
{% endif %}
{% if dns_servers is defined %}
    dns-nameservers {{ dns_servers | join(' ') }}
{% endif %}
