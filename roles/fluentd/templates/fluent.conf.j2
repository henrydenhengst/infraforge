<source>
  @type forward
  port 24224
  bind 0.0.0.0
</source>

<source>
  @type http
  port 9880
  bind 0.0.0.0
</source>

<source>
  @type tail
  path /var/log/*.log
  pos_file /fluentd/log/pos.log
  tag host.*
  <parse>
    @type none
  </parse>
</source>

<match **>
  @type loki
  url "{{ fluentd_loki_url }}"
  flush_interval 10s
  flush_at_shutdown true
  buffer_chunk_limit 1m
  <label>
    host "{{ inventory_hostname }}"
  </label>
</match>
