# {{ ansible_managed }}
# Promtail configuration

server:
  http_listen_port: {{ promtail_listen_port }}

positions:
  filename: /var/lib/loki/positions.yaml

clients:
  - url: http://localhost:{{ loki_listen_port }}/loki/api/v1/push

scrape_configs:
  - job_name: system
    static_configs:
      - targets:
          - localhost
        labels:
          job: system
          host: {{ inventory_hostname }}
          __path__: /var/log/*log

  - job_name: docker
    static_configs:
      - targets:
          - localhost
        labels:
          job: docker
          host: {{ inventory_hostname }}
          __path__: /var/lib/docker/containers/*/*.log

  - job_name: syslog
    syslog:
      listen_address: 0.0.0.0:1514
      label_structured_data: yes
      labels:
        job: syslog
        host: {{ inventory_hostname }}

  - job_name: journal
    journal:
      path: /var/log/journal
      max_age: 12h
      labels:
        job: journal
        host: {{ inventory_hostname }}
    relabel_configs:
      - source_labels: ['__journal__systemd_unit']
        target_label: 'unit'
