# {{ ansible_managed }}
# Nginx virtual host voor {{ app.name }}

server {
    listen 80;
    server_name {{ app.name }}.{{ domain }};
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name {{ app.name }}.{{ domain }};

    ssl_certificate /etc/nginx/ssl/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/{{ domain }}/privkey.pem;

    location / {
        proxy_pass http://localhost:{{ app.network_requirements.ports[0].host }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location {{ health_endpoint }} {
        proxy_pass http://localhost:{{ app.network_requirements.ports[0].host }}{{ health_endpoint }};
        access_log off;
    }

    {% if metrics_endpoint is defined %}
    location {{ metrics_endpoint }} {
        proxy_pass http://localhost:{{ app.network_requirements.ports[0].host }}{{ metrics_endpoint }};
        access_log off;
    }
    {% endif %}
}
