# {{ ansible_managed }}
# Audit rules

# Remove any existing rules
-D

# Buffer size
-b 8192

# Failure mode
-f 1

# Monitoring file system mounts
-a always,exit -S mount -F auid>=1000 -F auid!=4294967295 -k mounts

# Monitoring file deletions and renames
-a always,exit -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k delete

# Monitoring file permissions
-a always,exit -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod

# Monitoring user and group changes
-w /etc/passwd -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/sudoers -p wa -k identity

# Monitoring network configuration changes
-w /etc/hosts -p wa -k system-locale
-w /etc/network -p wa -k system-locale

# Monitoring system logins
-w /var/log/faillog -p wa -k logins
-w /var/log/lastlog -p wa -k logins
-w /var/log/tallylog -p wa -k logins

# Monitoring SSH configuration
-w /etc/ssh/sshd_config -p wa -k sshd

# Monitoring system binaries
-w /usr/bin/passwd -p x -k passwd
-w /usr/bin/sudo -p x -k sudo
-w /usr/bin/su -p x -k su

# Make the configuration immutable
-e 2
