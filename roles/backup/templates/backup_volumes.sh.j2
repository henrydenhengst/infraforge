#!/bin/bash
# {{ ansible_managed }}
# Docker volumes backup script

BACKUP_TYPE="${1:-daily}"
BACKUP_DIR="{{ backup_base_dir }}/volumes/$BACKUP_TYPE"
LOG_FILE="{{ backup_log_dir }}/volumes-backup.log"
DATE=$(date +%Y%m%d-%H%M%S)

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

mkdir -p "$BACKUP_DIR"

{% if backup_docker_volumes %}
log "Backing up Docker volumes"
for volume in $(docker volume ls -q); do
    log "  Backing up volume: $volume"
    docker run --rm -v $volume:/data -v $BACKUP_DIR:/backup alpine tar czf /backup/$volume-$DATE.tar.gz -C /data .
done
{% endif %}

{% for volume in backup_volumes_list %}
log "Backing up volume: {{ volume }}"
tar czf "$BACKUP_DIR/{{ volume }}-$DATE.tar.gz" -C {{ volume }} .
{% endfor %}

log "Volume backup completed"
