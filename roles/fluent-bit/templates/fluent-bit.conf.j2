[SERVICE]
    Flush        1
    Daemon       Off
    Log_Level    info
    Parsers_File parsers.conf
    HTTP_Server  On
    HTTP_Listen  0.0.0.0
    HTTP_Port    2020

[INPUT]
    Name              tail
    Path              /var/log/*.log
    Tag               host.*
    Refresh_Interval  10

[INPUT]
    Name              docker
    Tag               docker.*
    Mem_Buf_Limit     50MB

[FILTER]
    Name              record_modifier
    Match             *
    Record            host {{ inventory_hostname }}

[OUTPUT]
    Name              loki
    Match             *
    Host              loki
    Port              3100
    Labels            job=fluent-bit, host={{ inventory_hostname }}
    Auto_Kubernetes_Labels Off
